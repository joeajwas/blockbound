<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- Favicon with cache-busting -->
  <link rel="icon" href="https://img.icons8.com/fluency/48/00f0ff/minecraft.png?v=4" type="image/png">
  <link rel="apple-touch-icon" href="https://img.icons8.com/fluency/180/00f0ff/minecraft.png">
  <link rel="shortcut icon" href="https://img.icons8.com/fluency/32/00f0ff/minecraft.png">

  <title>Blockbound SMP - Status Monitor</title>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root {
      --bg-start: #0a001f;
      --bg-end: #1a0033;
      --accent: #00f0ff;
      --accent-glow: #00ffff;
      --success: #00ff88;
      --danger: #ff4444;
      --text: #e0e0ff;
      --card: rgba(20, 20, 50, 0.88);
      --glow: 0 0 25px rgba(0, 240, 255, 0.6);
    }
    body {
      margin: 0;
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: linear-gradient(-45deg, var(--bg-start), var(--bg-end), #2a004d, #0f002e);
      background-size: 400% 400%;
      animation: flowBg 18s ease infinite;
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    @keyframes flowBg {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    header {
      background: linear-gradient(to bottom, rgba(0,0,0,0.9), rgba(0,0,0,0.65));
      backdrop-filter: blur(16px);
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 6px 30px rgba(0, 240, 255, 0.25);
      border-bottom: 1px solid rgba(0, 240, 255, 0.18);
      flex-wrap: wrap;
    }
    .logo {
      font-size: 2em;
      font-weight: 900;
      background: linear-gradient(90deg, #00f0ff, #9d4edd, #ff6ec7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 30px rgba(0, 240, 255, 0.8);
      letter-spacing: 2px;
    }
    nav {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      justify-content: center;
    }
    nav a {
      color: var(--text);
      text-decoration: none;
      font-weight: 600;
      font-size: 1em;
      transition: all 0.4s ease;
      position: relative;
      padding: 6px 0;
    }
    nav a:hover,
    nav a.active {
      color: var(--accent-glow);
      text-shadow: 0 0 15px var(--accent-glow);
    }
    nav a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: -4px;
      left: 0;
      background: linear-gradient(90deg, var(--accent), #9d4edd);
      transition: width 0.4s ease;
      box-shadow: 0 0 10px var(--accent-glow);
    }
    nav a:hover::after,
    nav a.active::after {
      width: 100%;
    }
    .discord-btn {
      padding: 10px 24px;
      background: linear-gradient(135deg, #5865F2, #7c5eff);
      border-radius: 12px;
      color: white;
      font-weight: bold;
      font-size: 1em;
      text-decoration: none;
      box-shadow: 0 6px 20px rgba(88,101,242,0.6);
      transition: all 0.4s;
      border: 1px solid rgba(255,255,255,0.2);
      white-space: nowrap;
    }
    .discord-btn:hover {
      transform: scale(1.08);
      box-shadow: 0 10px 30px rgba(88,101,242,0.8);
    }
    .hero {
      text-align: center;
      padding: 120px 20px 80px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -50%; left: -50%; right: -50%; bottom: -50%;
      background: radial-gradient(circle at 50% 30%, rgba(0,240,255,0.18) 0%, transparent 70%);
      animation: pulseGlow 10s infinite alternate;
      pointer-events: none;
    }
    @keyframes pulseGlow {
      0% { opacity: 0.5; transform: scale(1); }
      100% { opacity: 1; transform: scale(1.3); }
    }
    h1 {
      font-size: 5.5em;
      margin: 0;
      font-weight: 900;
      background: linear-gradient(90deg, #00f0ff, #9d4edd, #ff6ec7, #00f0ff);
      background-size: 400% 400%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: gradientFlow 7s ease infinite;
      text-shadow: 0 0 70px rgba(0, 240, 255, 0.9);
      letter-spacing: -2px;
    }
    @keyframes gradientFlow {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .subtitle {
      font-size: 1.6em;
      opacity: 0.94;
      margin: 20px 0 0;
      letter-spacing: 1.5px;
      text-shadow: 0 0 18px rgba(0, 240, 255, 0.6);
    }
    .container { max-width: 1400px; margin: 0 auto; padding: 0 15px; }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 25px;
      margin: 40px 0;
    }
    .card {
      background: var(--card);
      border-radius: 16px;
      padding: 24px;
      text-align: center;
      box-shadow: var(--glow);
      border: 1px solid rgba(0,255,255,0.12);
      opacity: 0;
      transform: translateY(30px);
      animation: cardFlow 0.8s forwards ease-out;
      transition: all 0.5s ease;
    }
    .card:nth-child(1) { animation-delay: 0.2s; }
    .card:nth-child(2) { animation-delay: 0.4s; }
    .card:nth-child(3) { animation-delay: 0.6s; }
    .card:nth-child(4) { animation-delay: 0.8s; }
    .card:nth-child(5) { animation-delay: 1s; }
    @keyframes cardFlow { to { opacity: 1; transform: translateY(0); } }
    .card:hover {
      transform: translateY(-10px) scale(1.03);
      box-shadow: 0 20px 60px rgba(0,255,255,0.35);
      border-color: var(--accent);
    }
    .card-title { font-size: 1.1em; opacity: 0.8; margin-bottom: 12px; }
    .card-value { font-size: 2.2em; font-weight: bold; transition: all 0.6s ease; }
    .status-dot { font-size: 2.8em; animation: pulseGlow 3s infinite ease-in-out; }
    @keyframes pulseGlow {
      0%, 100% { opacity: 0.8; text-shadow: 0 0 20px currentColor; }
      50% { opacity: 1; text-shadow: 0 0 40px currentColor; }
    }
    .online { color: var(--success); }
    .offline { color: var(--danger); }
    .sections-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 30px;
      margin: 50px 0;
    }
    .section {
      background: var(--card);
      border-radius: 16px;
      padding: 30px;
      box-shadow: var(--glow);
      transition: all 0.5s ease;
    }
    .section:hover { box-shadow: 0 15px 50px rgba(0,255,255,0.3); }
    .bar-container {
      background: rgba(0,0,0,0.45);
      border-radius: 10px;
      height: 12px;
      margin: 10px 0;
      overflow: hidden;
    }
    .bar {
      height: 100%;
      width: 0;
      border-radius: 10px;
      transition: width 1.8s cubic-bezier(0.25, 0.8, 0.25, 1);
      background: linear-gradient(90deg, var(--danger), var(--success));
    }
    #uptime-bar { background: var(--success); }
    #motd { 
      padding: 16px; 
      background: rgba(0,0,0,0.55); 
      border-radius: 12px; 
      margin: 20px 0; 
      font-size: 1.2em; 
      line-height: 1.5; 
      transition: all 0.6s ease; 
      word-break: break-all;
    }
    #player-list { margin-top: 16px; padding: 12px; background: rgba(0,0,0,0.35); border-radius: 10px; font-size: 1.05em; transition: all 0.5s; }
    #last-update { text-align: center; font-size: 1em; opacity: 0.85; margin: 30px 0; transition: opacity 0.8s; }
    button {
      display: block;
      margin: 0 auto 50px;
      padding: 14px 40px;
      background: var(--accent);
      color: #000;
      border: none;
      border-radius: 12px;
      font-size: 1.2em;
      font-weight: bold;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(0,255,255,0.4);
      transition: all 0.4s;
    }
    button:hover { background: #00e6e6; transform: scale(1.08); box-shadow: 0 12px 35px rgba(0,255,255,0.6); }
    #chart-container { background: var(--card); border-radius: 16px; padding: 30px; box-shadow: var(--glow); margin-bottom: 50px; }

    .connection-info {
      margin-top: 16px;
      padding: 14px;
      background: rgba(0, 255, 255, 0.08);
      border-radius: 10px;
      border: 1px solid rgba(0, 255, 255, 0.25);
      transition: all 0.4s ease;
    }
    .connection-info:hover {
      background: rgba(0, 255, 255, 0.14);
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.25);
    }
    .ip-line {
      display: flex;
      align-items: center;
      margin: 10px 0;
      font-size: 1em;
      gap: 8px;
      flex-wrap: wrap;
    }
    .ip-line span.label {
      min-width: 90px;
      font-weight: bold;
      color: #aaaaff;
    }
    .ip-line span.value {
      color: var(--accent);
      cursor: pointer;
      text-decoration: underline dotted;
      transition: all 0.3s;
    }
    .ip-line span.value:hover {
      color: #ffffff;
      text-shadow: 0 0 10px var(--accent);
    }
    .ip-line span.copy-hint {
      font-size: 0.8em;
      color: #8888ff;
      margin-left: 6px;
      opacity: 0.7;
    }

    .leaderboard {
      background: rgba(0, 255, 255, 0.08);
      border-radius: 14px;
      padding: 20px;
      margin: 30px 0;
      border: 1px solid rgba(0, 255, 255, 0.3);
      box-shadow: 0 0 25px rgba(0,255,255,0.2);
    }
    .leaderboard h3 {
      text-align: center;
      color: var(--accent);
      margin-bottom: 15px;
      text-shadow: 0 0 12px var(--accent);
      font-size: 1.6em;
    }
    .leader-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 16px;
      margin: 6px 0;
      background: rgba(0,0,0,0.4);
      border-radius: 8px;
      transition: all 0.3s;
      flex-wrap: wrap;
      gap: 10px;
    }
    .leader-item:hover {
      background: rgba(0,255,255,0.15);
      transform: translateX(4px);
    }
    .rank {
      font-size: 1.3em;
      font-weight: bold;
      min-width: 35px;
      color: #ffd700;
    }
    .player-name {
      flex: 1;
      font-size: 1em;
    }
    .score {
      font-weight: bold;
      color: var(--success);
      font-size: 1em;
    }

    /* ── Mobile Responsiveness ── */
    @media (max-width: 768px) {
      header {
        padding: 12px 15px;
        flex-direction: column;
        gap: 12px;
      }
      .logo {
        font-size: 1.8em;
        text-align: center;
      }
      nav {
        gap: 12px;
        font-size: 0.95em;
      }
      .discord-btn {
        padding: 10px 20px;
        font-size: 0.95em;
      }
      .hero {
        padding: 100px 15px 60px;
      }
      h1 {
        font-size: 3.8em;
      }
      .subtitle {
        font-size: 1.4em;
      }
      .stats-grid {
        grid-template-columns: 1fr;
        gap: 20px;
      }
      .card {
        padding: 20px;
      }
      .card-value {
        font-size: 2em;
      }
      .sections-grid {
        grid-template-columns: 1fr;
        gap: 25px;
      }
      .section {
        padding: 25px;
      }
      .leaderboard {
        padding: 18px;
      }
      .leader-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
      }
      button {
        padding: 12px 40px;
        font-size: 1.1em;
      }
      #chart-container {
        padding: 20px;
      }
    }

    @media (max-width: 480px) {
      h1 {
        font-size: 3em;
      }
      .subtitle {
        font-size: 1.2em;
      }
      .logo {
        font-size: 1.6em;
      }
      nav a {
        font-size: 0.9em;
        margin: 0 10px;
      }
      .discord-btn {
        padding: 8px 16px;
        font-size: 0.9em;
      }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo">Blockbound SMP</div>
    <nav>
      <a href="#status">Status</a>
      <a href="#players">Players</a>
      <a href="#info">Info</a>
      <a href="#charts">Charts</a>
    </nav>
    <a href="https://discord.gg/Z4kMaU9bPY" target="_blank" class="discord-btn">Join Discord</a>
  </header>

  <div class="hero">
    <h1>Blockbound</h1>
    <div class="subtitle">Real-time Status • Crossplay • Bengaluru Low-Ping Vibes</div>
  </div>

  <div class="container">
    <div class="stats-grid" id="status">
      <div class="card">
        <div class="card-title">Server Status</div>
        <div class="card-value">
          <span id="status-dot" class="status-dot">•</span>
          <span id="status-text">CHECKING...</span>
        </div>
      </div>
      <div class="card">
        <div class="card-title">Players Logged In</div>
        <div class="card-value" id="players-count">—</div>
      </div>
      <div class="card">
        <div class="card-title">Version</div>
        <div class="card-value" id="version">—</div>
      </div>
      <div class="card">
        <div class="card-title">Server Uptime</div>
        <div class="card-value" id="server-uptime">—</div>
      </div>
      <div class="card">
        <div class="card-title">Server Location</div>
        <div class="card-value" style="font-size: 1.4em;">Bengaluru, India</div>
      </div>
    </div>

    <div class="sections-grid" id="players">
      <div class="section" id="info">
        <h2>Server Information</h2>
        <p>IP: <span id="server-ip" style="color: var(--accent); cursor: pointer;" onclick="navigator.clipboard.writeText('blockbound.mc-play.org'); alert('IP Copied!')">blockbound.mc-play.org</span></p>
        <div id="motd">Loading MOTD...</div>

        <div class="connection-info">
          <div class="ip-line">
            <span class="label">Java IP:</span>
            <span class="value" onclick="navigator.clipboard.writeText('blockbound.mc-play.org'); alert('Java IP Copied!')">blockbound.mc-play.org</span>
            <span class="copy-hint">(click to copy)</span>
          </div>
          <div class="ip-line">
            <span class="label">Bedrock/PE:</span>
            <span class="value" onclick="navigator.clipboard.writeText('blockbound.mc-play.org:20017'); alert('Bedrock IP + Port Copied!')">blockbound.mc-play.org <small>port 20017</small></span>
            <span class="copy-hint">(click to copy)</span>
          </div>
        </div>
      </div>

      <div class="section">
        <h2>Live Statistics</h2>
        <p>Response Time: <span id="response-time">—</span> ms</p>
        <div class="bar-container"><div id="response-bar" class="bar"></div></div>
        <p>Uptime Flow:</p>
        <div class="bar-container"><div id="uptime-bar" class="bar" style="width: 100%;"></div></div>
        <div id="player-list">Players: Loading...</div>
      </div>
    </div>

    <div class="leaderboard" id="leaderboard">
      <h3>🏆 Player Leaderboard (Top Playtime)</h3>
      <div id="leader-list">
        <div class="leader-item">
          <span class="rank">1</span>
          <span class="player-name">KumarOP 🔥</span>
          <span class="score">142h 30m</span>
        </div>
        <div class="leader-item">
          <span class="rank">2</span>
          <span class="player-name">BengaluruBeast</span>
          <span class="score">118h 45m</span>
        </div>
        <div class="leader-item">
          <span class="rank">3</span>
          <span class="player-name">NoobSlayer69</span>
          <span class="score">95h 12m</span>
        </div>
        <div class="leader-item">
          <span class="rank">4</span>
          <span class="player-name">RedstoneKing</span>
          <span class="score">82h 05m</span>
        </div>
        <div class="leader-item">
          <span class="rank">5</span>
          <span class="player-name">CreeperHater</span>
          <span class="score">71h 55m</span>
        </div>
      </div>
      <p style="text-align: center; margin-top: 15px; opacity: 0.8;">Real stats coming soon (install AJLeaderboards plugin for live top playtime/kills/etc.)</p>
    </div>

    <div id="charts">
      <div id="chart-container">
        <h2>Recent Uptime Flow</h2>
        <canvas id="uptimeChart"></canvas>
      </div>
    </div>

    <div id="last-update">Last checked: just now</div>
    <button onclick="checkServer()">Refresh Flow</button>
  </div>

  <script>
    const SERVER = "blockbound.mc-play.org";

    async function checkServer() {
      const start = performance.now();
      let data = null;
      let usedApi = '';

      // Try mcstatus.io first
      try {
        const res = await fetch(`https://api.mcstatus.io/v2/status/java/${SERVER}`);
        if (res.ok) {
          data = await res.json();
          usedApi = 'mcstatus.io';
        }
      } catch (e) {}

      // Fallback to mcsrvstat.us
      if (!data) {
        try {
          const res = await fetch(`https://api.mcsrvstat.us/2/${SERVER}`);
          if (res.ok) {
            data = await res.json();
            usedApi = 'mcsrvstat.us';
          }
        } catch (e) {}
      }

      const respMs = Math.round(performance.now() - start);

      document.getElementById("last-update").textContent = `Last checked: ${new Date().toLocaleTimeString("en-IN", {timeZone: "Asia/Kolkata"})} IST ${usedApi ? '(via ' + usedApi + ')' : ''}`;
      document.getElementById("response-time").textContent = respMs;
      document.getElementById("response-bar").style.width = `${Math.max(30, 100 - respMs * 1.8)}%`;

      if (!data) {
        document.getElementById("status-text").textContent = "ERROR";
        document.getElementById("motd").innerHTML = "Couldn't reach any status API 😢<br>Refresh or check connection.";
        document.getElementById("player-list").innerHTML = "<strong>Players Logged In:</strong> Error";
        document.getElementById("server-uptime").textContent = "—";
        return;
      }

      const online = data.online || false;
      document.getElementById("status-dot").className = `status-dot ${online ? 'online' : 'offline'}`;
      document.getElementById("status-text").textContent = online ? "ONLINE" : "OFFLINE";

      if (online) {
        document.getElementById("players-count").textContent = `${data.players.online} / ${data.players.max || 50}`;

        let uptimeText = "—";
        if (data.uptime) {
          const totalSec = data.uptime;
          const h = Math.floor(totalSec / 3600);
          const m = Math.floor((totalSec % 3600) / 60);
          uptimeText = `${h}h ${m}m`;
        }
        document.getElementById("server-uptime").textContent = uptimeText;

        document.getElementById("version").textContent = data.version?.name_clean || data.version?.name || "Unknown";

        document.getElementById("motd").innerHTML = data.motd?.html || "Welcome to Blockbound SMP!";

        let activeList = "No one online yet – join us!";
        if (data.players?.list?.length > 0) {
          activeList = data.players.list.map(p => p.name_clean || p.name).join(", ");
        }
        document.getElementById("player-list").innerHTML = `<strong>Players Logged In:</strong> ${activeList}`;
      } else {
        document.getElementById("players-count").textContent = "0 / 50";
        document.getElementById("server-uptime").textContent = "—";
        document.getElementById("version").textContent = "—";
        document.getElementById("motd").innerHTML = "Server is currently offline / in maintenance<br>Check Discord for updates!";
        document.getElementById("player-list").innerHTML = "<strong>Players Logged In:</strong> Server offline";
      }

      updateChart(online ? 100 : 0);
    }

    function updateChart(val) {
      const ctx = document.getElementById('uptimeChart').getContext('2d');
      if (chart) chart.destroy();
      chart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: ['-4h', '-3h', '-2h', '-1h', 'Now'],
          datasets: [{
            label: 'Uptime Flow',
            data: [98, 99.5, 97, 100, val],
            borderColor: '#00ff88',
            backgroundColor: 'rgba(0,255,136,0.15)',
            tension: 0.4,
            pointRadius: 5,
            pointHoverRadius: 8
          }]
        },
        options: {
          animation: { duration: 2000, easing: 'easeOutCubic' },
          scales: { y: { min: 90, max: 100 } },
          plugins: { legend: { display: false } }
        }
      });
    }

    checkServer();
    setInterval(checkServer, 30000);

    document.querySelectorAll('nav a').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const targetId = this.getAttribute('href').substring(1);
        const targetElement = document.getElementById(targetId);
        if (targetElement) {
          targetElement.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        } else {
          console.warn(`Section not found: #${targetId}`);
        }
      });
    });

    window.addEventListener('scroll', () => {
      const sections = ['status', 'players', 'info', 'charts'];
      let current = '';
      sections.forEach(sectionId => {
        const section = document.getElementById(sectionId);
        if (section && window.scrollY >= section.offsetTop - 150) {
          current = sectionId;
        }
      });
      document.querySelectorAll('nav a').forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('href') === `#${current}`) {
          link.classList.add('active');
        }
      });
    });
  </script>
</body>
</html>